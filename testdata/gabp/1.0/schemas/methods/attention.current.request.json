      "description": "Protocol version identifier"
    },
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique request identifier"
    },
    "type": {
      "const": "request",
      "description": "Message type"
    },
    "method": {
      "const": "attention/current",
      "description": "Method name"
    },
    "params": {
      "type": "object",
      "additionalProperties": false,
      "default": {}
    }
  },
  "additionalProperties": false
}
