{
  "$id": "https://gabp.dev/schema/1.0/methods/attention.current.request.json",
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "attention/current Request",
  "description": "Request schema for retrieving the current open attention item",
  "type": "object",
  "required": ["v", "id", "type", "method"],
  "properties": {
    "v": {
