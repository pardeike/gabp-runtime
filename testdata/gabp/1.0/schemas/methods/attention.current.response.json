{
  "$id": "https://gabp.dev/schema/1.0/methods/attention.current.response.json",
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "attention/current Response",
  "description": "Response schema for retrieving the current open attention item",
  "type": "object",
  "required": ["v", "id", "type", "result"],
  "properties": {
    "v": {
      "const": "gabp/1",
      "description": "Protocol version identifier"
    },
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Request identifier this response corresponds to"
    },
    "type": {
      "const": "response",
      "description": "Message type"
    },
    "result": {
      "type": "object",
      "required": ["attention"],
      "properties": {
        "attention": {
          "description": "Current open attention item, or null when none is open",
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "../common/attention.schema.json"
            }
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
